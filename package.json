{
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.17.0",
  "files": [
    "./**/*js"
  ],
  "scripts": {
    "🧱build": "tsx dev/make_pack.ts",
    "⚡dobious-perf": "sed -i 's/listAllPartMaterials=true/listAllPartMaterials=false/' config/tconstruct.cfg && git update-index --assume-unchanged config/tconstruct.cfg && sed -i 's/NBTTagImprovements=true/NBTTagImprovements=false/' config/stellar_core.cfg && git update-index --assume-unchanged config/stellar_core.cfg",
    "dev": "concurrently --prefix-colors auto \"npm:dev:* --silent\"",
    "dev:benchmark": "npx mc-benchmark > dev/benchmarks/latest.md",
    "dev:conflicts": "grep 'conflicts with' crafttweaker.log | sort | uniq | grep -Evf dev/tools/conflict.ignore | sed \"s/^[^ ]* //\" >&2",
    "dev:entities": "tsx dev/automation/entities.js",
    "dev:errors": "tsx mc-tools/packages/errors/src/cli.ts --config=dev/tools/mct-errors-config.yml --output=dev/tools/unresolved-errors.log",
    "dev:ftbq_cleanup": "tsx mc-tools/scripts/ftbq_cleanup.ts",
    "dev:inject_js": "tsx dev/automation/Inject_JS.js",
    "dev:jei": "tsx dev/automation/jei.js",
    "dev:jer": "tsx dev/automation/jer.ts",
    "dev:manifest": "tsx mc-tools/packages/manifest/src/cli.ts --verbose --ignore=dev/.devonly.ignore --key=~secrets/cf_api_key.txt",
    "dev:misc": "tsx dev/automation/misc.js --keep-cache",
    "dev:modlist": "tsx mc-tools/packages/modlist/src/cli.ts --old=../E2E-unchanged/minecraftinstance.json --verbose --ignore=dev/.devonly.ignore --key=~secrets/cf_api_key.txt --template=dev/tools/modlist_template.md --sort=addonID",
    "dev:tcon": "tsx mc-tools/packages/tcon/src/cli.ts --default=dev/default_configs/tweakersconstruct.cfg --tweaks=dev/tools/tcon/tweaks --save=dev/tools/tcon/stats",
    "dev:tips": "tsx dev/automation/tips.ts",
    "dev:xml": "tsx dev/automation/XML.js",
    "tellme-prune": "bash -c \"for prefix in $(ls -1 config/tellme/*.csv | xargs -n 1 basename | sed -e 's/_[0-9].*\\\\.csv$//' -e 's/\\\\.csv$//' | sort -u); do ls -1 config/tellme/\\\"${prefix}\\\"*.csv | sort -r | tail -n +2 | xargs -r rm; done\"",
    "reducer": "tsx mc-tools/packages/reducer/src/cli.ts"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "markdown-it": "^14.1.1",
    "mdimg": "1.5.0",
    "puppeteer": "^24.22.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@clack/prompts": "^1.1.0",
    "@conventional-changelog/git-client": "^2.6.0",
    "@types/adm-zip": "^0.5.8",
    "@types/fast-levenshtein": "^0.0.4",
    "@types/fs-extra": "^11.0.4",
    "@types/language-name-map": "^0.3.4",
    "@types/memoizee": "^0.4.12",
    "@types/node": "^25.5.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@types/terminal-kit": "^2.5.7",
    "@types/yargs": "^17.0.35",
    "adm-zip": "^0.5.16",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "concurrently": "^9.2.1",
    "consola": "^3.4.2",
    "conventional-changelog": "^7.2.0",
    "conventional-changelog-writer": "^8.4.0",
    "conventional-commits-parser": "^6.3.0",
    "csv-parse": "^6.2.0",
    "curseforge-v2": "^1.5.0",
    "del": "^8.0.1",
    "detect-indent": "^7.0.2",
    "eslint": "^10.0.3",
    "fast-glob": "^3.3.3",
    "fast-levenshtein": "^3.0.0",
    "fs-extra": "^11.3.4",
    "humanize-string": "^3.1.0",
    "ignore": "^7.0.5",
    "language-name-map": "^0.3.0",
    "lodash": "^4.17.23",
    "log-update": "^7.2.0",
    "mc-benchmark": "^2.1.0",
    "node-fetch": "^3.3.2",
    "pathe": "^2.0.3",
    "prismarine-nbt": "^2.8.0",
    "replace-in-file": "^8.4.0",
    "simplify-js": "^1.2.4",
    "ssh2-sftp-client": "^12.1.0",
    "table": "^6.9.0",
    "tinyglobby": "^0.2.15",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "xml-js": "^1.6.11",
    "yaml": "^2.8.2",
    "yargs": "^18.0.0",
    "zx": "^8.8.5"
  }
}
